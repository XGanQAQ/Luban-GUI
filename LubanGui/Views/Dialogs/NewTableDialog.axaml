<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LubanGui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="LubanGui.Views.Dialogs.NewTableDialog"
        x:DataType="vm:NewTableDialogViewModel"
        Title="新建表格"
        Width="600" Height="480"
        MinWidth="480" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Design.DataContext>
        <vm:NewTableDialogViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="16">

        <!-- 表格全名 -->
        <Grid Grid.Row="0" ColumnDefinitions="120,*" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" Text="表格全名:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                     Text="{Binding TableFullName}"
                     Watermark="如 cfg.ItemConfig" />
        </Grid>

        <!-- 索引字段 -->
        <Grid Grid.Row="1" ColumnDefinitions="120,*" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="索引字段:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                     Text="{Binding IndexField}"
                     Watermark="如 id" />
        </Grid>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="OrangeRed"
                   FontSize="12"
                   Margin="0,0,0,6"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- 字段列表 -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,8">
            <DockPanel Margin="8">

                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,6"
                            Spacing="8">
                    <TextBlock Text="字段列表" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Content="+ 添加字段"
                            Command="{Binding AddFieldCommand}"
                            Padding="8,2" />
                </StackPanel>

                <!-- 列标题 -->
                <Grid DockPanel.Dock="Top"
                      ColumnDefinitions="*,120,*,32"
                      Margin="0,0,0,4">
                    <TextBlock Grid.Column="0" Text="字段名" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Grid.Column="1" Text="类型" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Grid.Column="2" Text="注释" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </Grid>

                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Fields}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FieldDefinitionViewModel">
                                <Grid ColumnDefinitions="*,120,*,32" Margin="0,2">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Name}"
                                             Watermark="字段名"
                                             Margin="0,0,4,0" />
                                    <AutoCompleteBox Grid.Column="1"
                                                     Text="{Binding Type}"
                                                     ItemsSource="{Binding AvailableTypes}"
                                                     FilterMode="Contains"
                                                     Watermark="int, list,int, map,int,string…"
                                                     Margin="0,0,4,0" />
                                    <TextBox Grid.Column="2"
                                             Text="{Binding Comment}"
                                             Watermark="注释（可选）"
                                             Margin="0,0,4,0" />
                                    <Button Grid.Column="3"
                                            Content="✕"
                                            Command="{Binding RemoveCommand}"
                                            Padding="4,0"
                                            FontSize="11" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- 按钮行 -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="取消" Name="CancelButton" Padding="16,6" />
            <Button Content="创建"
                    Name="CreateButton"
                    IsEnabled="{Binding CanCreate}"
                    Padding="16,6" />
        </StackPanel>

    </Grid>
</Window>
