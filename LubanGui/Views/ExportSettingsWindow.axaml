<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LubanGui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="500"
        x:Class="LubanGui.Views.ExportSettingsWindow"
        x:DataType="vm:ExportConfigViewModel"
        Title="导出配置"
        Width="560" Height="500"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid RowDefinitions="*,Auto" Margin="16">

        <ScrollViewer Grid.Row="0"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">

                <!-- ▾ 数据导出 -->
                <Expander Header="数据导出" IsExpanded="True">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="100,*,80"
                          Margin="8,8,0,8" RowSpacing="8">

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="导出类型:" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                  ItemsSource="{x:Static vm:ExportConfigViewModel.DataOutputTypes}"
                                  SelectedItem="{Binding DataOutputType}"
                                  HorizontalAlignment="Stretch" Margin="8,0,0,0" />

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="输出路径:" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding DataOutputPath}"
                                 Watermark="导出数据文件的目标目录" Margin="8,0,4,0" />
                        <Button Grid.Row="1" Grid.Column="2"
                                Command="{Binding BrowseDataOutputPathCommand}"
                                HorizontalAlignment="Stretch">浏览</Button>
                    </Grid>
                </Expander>

                <!-- ▾ 代码导出 -->
                <Expander Header="代码导出" IsExpanded="True">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="100,*,80"
                          Margin="8,8,0,8" RowSpacing="8">

                        <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                  IsChecked="{Binding CodeOutputEnabled}"
                                  Content="生成代码" />

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="代码类型:" VerticalAlignment="Center"
                                   IsEnabled="{Binding CodeOutputEnabled}" />
                        <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                  ItemsSource="{x:Static vm:ExportConfigViewModel.CodeOutputTypes}"
                                  SelectedItem="{Binding CodeOutputType}"
                                  IsEnabled="{Binding CodeOutputEnabled}"
                                  HorizontalAlignment="Stretch" Margin="8,0,0,0" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="输出路径:" VerticalAlignment="Center"
                                   IsEnabled="{Binding CodeOutputEnabled}" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding CodeOutputPath}"
                                 IsEnabled="{Binding CodeOutputEnabled}"
                                 Watermark="生成代码文件的目标目录" Margin="8,0,4,0" />
                        <Button Grid.Row="2" Grid.Column="2"
                                Command="{Binding BrowseCodeOutputPathCommand}"
                                IsEnabled="{Binding CodeOutputEnabled}"
                                HorizontalAlignment="Stretch">浏览</Button>

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="顶层命名空间:" VerticalAlignment="Center"
                                   IsEnabled="{Binding CodeOutputEnabled}" />
                        <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                 Text="{Binding CodeOutputTopModule}"
                                 IsEnabled="{Binding CodeOutputEnabled}"
                                 Watermark="例: cfg" Margin="8,0,0,0" />
                    </Grid>
                </Expander>

                <!-- ▾ 导出目标 -->
                <Expander Header="导出目标" IsExpanded="True">
                    <Grid ColumnDefinitions="100,*" Margin="8,8,0,8">
                        <TextBlock Grid.Column="0" Text="目标:" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableTargets}"
                                  SelectedItem="{Binding Target}"
                                  HorizontalAlignment="Stretch" Margin="8,0,0,0" />
                    </Grid>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button x:Name="CancelButton" Padding="16,8">取消</Button>
            <Button x:Name="SaveButton" Padding="16,8">保存并关闭</Button>
        </StackPanel>

    </Grid>

</Window>
