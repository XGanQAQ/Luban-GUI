<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LubanGui.ViewModels"
        xmlns:models="using:LubanGui.Models"
        xmlns:converters="using:LubanGui.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="LubanGui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Luban 导表工具"
        Width="1100" Height="750"
        MinWidth="800" MinHeight="600">

    <Window.Resources>
        <converters:ExportStatusToBrushConverter x:Key="ExportStatusToBrushConverter" />
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- ===== 菜单栏 ===== -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">

            <!-- 下拉菜单（VS Code 风格：悬停展开） -->
            <Menu Grid.Column="0" Background="Transparent">

                <!-- 文件(F) -->
                <MenuItem Header="文件(_F)">
                    <MenuItem Header="新建项目(_N)..."
                              Command="{Binding NewProjectCommand}"
                              InputGesture="Ctrl+N" />
                    <MenuItem Header="打开项目(_O)..."
                              Command="{Binding OpenProjectCommand}"
                              InputGesture="Ctrl+O" />
                    <Separator />
                    <MenuItem Header="退出(_X)"
                              Command="{Binding ExitCommand}" />
                </MenuItem>

                <!-- 操作(A) -->
                <MenuItem Header="操作(_A)">
                    <MenuItem Header="▶ 全量导表(_E)"
                              Command="{Binding ExportCommand}"
                              InputGesture="F5" />
                    <MenuItem Header="✅ 校验配置(_V)"
                              Command="{Binding ValidateConfigCommand}"
                              InputGesture="F6" />
                    <Separator />
                    <MenuItem Header="⏹ 取消(_C)"
                              Command="{Binding CancelCommand}" />
                    <Separator />
                    <MenuItem Header="⚙ 导出设置(_S)..."
                              Command="{Binding OpenExportSettingsCommand}"
                              InputGesture="Ctrl+OemComma" />
                </MenuItem>

                <!-- 视图(V) -->
                <MenuItem Header="视图(_V)">
                    <MenuItem Header="📋 日志窗口(_L)"
                              Command="{Binding OpenLogWindowCommand}"
                              InputGesture="Ctrl+L" />
                    <Separator />
                    <MenuItem Header="刷新表格列表(_R)"
                              Command="{Binding RefreshTablesCommand}" />
                </MenuItem>

                <!-- 帮助(H) -->
                <MenuItem Header="帮助(_H)">
                    <MenuItem Header="关于 Luban-GUI(_A)"
                              Command="{Binding ShowAboutCommand}" />
                </MenuItem>

            </Menu>

            <!-- 状态指示器（菜单栏右侧） -->
            <TextBlock Grid.Column="1"
                       Text="{Binding StatusText}"
                       Foreground="{Binding ExportStatus, Converter={StaticResource ExportStatusToBrushConverter}}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />
        </Grid>
        </Border>

        <!-- ===== 项目切换栏 ===== -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="项目:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding Projects}"
                          SelectedItem="{Binding CurrentProject}"
                          MinWidth="160"
                          MaxWidth="300">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ProjectInfo">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="+ 新建项目"
                        Command="{Binding NewProjectCommand}" />
                <Button Content="📂 打开项目文件夹"
                        Command="{Binding OpenProjectFolderCommand}"
                        IsEnabled="{Binding HasCurrentProject}" />
                <Button Content="📁 打开已有项目..."
                        Command="{Binding OpenProjectCommand}" />
            </StackPanel>
        </Border>

        <!-- ===== 快捷操作工具栏 ===== -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="+ 新建表格"
                        IsEnabled="{Binding HasCurrentProject}"
                        ToolTip.Tip="新建数据表（Week 3 实现）" />
                <Button Content="+ 新建枚举"
                        IsEnabled="{Binding HasCurrentProject}"
                        ToolTip.Tip="新建枚举（Week 3 实现）" />
                <Button Content="+ 新建 Bean"
                        IsEnabled="{Binding HasCurrentProject}"
                        ToolTip.Tip="新建 Bean（Week 3 实现）" />
                <Button Content="📥 导入文件"
                        IsEnabled="{Binding HasCurrentProject}"
                        ToolTip.Tip="导入已有 xlsx（Week 3 实现）" />
            </StackPanel>
        </Border>

        <!-- ===== 主内容区：左右分栏 ===== -->
        <Grid Grid.Row="3" ColumnDefinitions="240,5,*" Margin="0,4,0,0">

            <!-- ─── 左侧：表格列表面板 ─── -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel Margin="4,4,4,4">

                    <!-- 面板标题 -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="📋 表格列表"
                               FontWeight="SemiBold"
                               Margin="4,0,0,6" />

                    <!-- 过滤框 -->
                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding TableFilter}"
                             Watermark="🔍 过滤..."
                             Margin="0,0,0,4" />

                    <!-- 无配置提示（Tables 为空时显示） -->
                    <TextBlock DockPanel.Dock="Top"
                               IsVisible="{Binding !Tables.Count}"
                               Text="请先在「操作 > 导出设置」中配置 Luban 路径和配置文件"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               FontSize="12"
                               Margin="4,8,4,0" />

                    <!-- 表格列表 -->
                    <ListBox ItemsSource="{Binding Tables}"
                             SelectedItem="{Binding SelectedTable}"
                             Background="Transparent"
                             Padding="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TableEntryViewModel">
                                <Grid ColumnDefinitions="*,Auto" Margin="2,1">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StatusIcon}"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               FontSize="11" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </Border>

            <!-- ─── GridSplitter ─── -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                          ResizeDirection="Columns" />

            <!-- ─── 右侧：表格内容面板 ─── -->
            <Border Grid.Column="2" Margin="4,0,4,4">
                <Grid RowDefinitions="Auto,*">

                    <!-- 面板标题栏 -->
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          Margin="0,0,0,4"
                          IsVisible="{Binding SelectedTable, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding SelectedTable.Name, StringFormat='📄 {0}'}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- 无表格选中时的占位提示 -->
                    <Border Grid.Row="1"
                            IsVisible="{Binding SelectedTable, Converter={x:Static ObjectConverters.IsNull}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <TextBlock Text="← 请在左侧列表中选择一张表格"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   FontSize="14" />
                    </Border>

                    <!-- 表格内容占位（选中后显示） -->
                    <Border Grid.Row="1"
                            IsVisible="{Binding SelectedTable, Converter={x:Static ObjectConverters.IsNotNull}}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <TextBlock Text="数据预览功能将在后续版本实现"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   FontSize="13" />
                    </Border>

                </Grid>
            </Border>

        </Grid>

        <!-- ===== 状态栏 ===== -->
        <Border Grid.Row="4"
                Height="24"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding LastExportStatusText}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding AppVersion}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </Grid>
        </Border>

    </Grid>

</Window>
